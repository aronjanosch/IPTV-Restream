STORAGE_PATH=/streams/
DB_PATH=/data/streamhub.db

# =============================================================================
# VPN — keep both blocks in .env; pick stack with -f docker-compose.<vpn>.yml
# =============================================================================

# --- AirVPN (docker compose -f docker-compose.airvpn.yml) ---
# Copy from ~/glueton/AirVPN_Switzerland_UDP-1637-Entry3.conf (or your entry).
# Gluetun needs WIREGUARD_ENDPOINT_IP as an IP: getent hosts ch3.vpn.airdns.org
AIRVPN_WIREGUARD_PRIVATE_KEY=
AIRVPN_WIREGUARD_PRESHARED_KEY=
# IPv4 /32 only from Address= (omit the IPv6 part unless Docker+gluetun IPv6 is configured)
AIRVPN_WIREGUARD_ADDRESSES=
AIRVPN_WIREGUARD_ENDPOINT_IP=
# Optional overrides (defaults match Switzerland UDP-1637 Entry3):
#AIRVPN_WIREGUARD_PUBLIC_KEY=PyLCXAQT8KkM4T+dUsOQfn+Ub3pGxfGlxkIApuig+hk=
#AIRVPN_WIREGUARD_ENDPOINT_PORT=1637
# Optional server filter (WireGuard): scripts/airvpn-zurich-servers.txt lists Zurich names
#AIRVPN_SERVER_COUNTRIES=Switzerland
#AIRVPN_SERVER_NAMES=Achernar
# One HEAD probe: ./scripts/airvpn-try-server.sh <ServerName> 'http://.../live/.../....m3u8'
# (script clears country filter unless you set AIRVPN_SERVER_COUNTRIES=... on the same command)

# --- ProtonVPN (docker compose -f docker-compose.protonvpn.yml) ---
# Download a WireGuard config for the server you want (e.g. DE#677). Map fields:
#   PrivateKey  -> PROTON_WIREGUARD_PRIVATE_KEY
#   Address     -> PROTON_WIREGUARD_ADDRESSES   (IPv4 /32 only unless Docker IPv6+gluetun)
#   [Peer] PublicKey -> PROTON_WIREGUARD_PUBLIC_KEY
#   Endpoint IP:port -> PROTON_WIREGUARD_ENDPOINT_IP (+ PROTON_WIREGUARD_ENDPOINT_PORT)
# UI names like "DE#677" are comments only; the Endpoint line is what gluetun needs.
PROTON_WIREGUARD_PRIVATE_KEY=
PROTON_WIREGUARD_PUBLIC_KEY=
PROTON_WIREGUARD_ADDRESSES=
PROTON_WIREGUARD_ENDPOINT_IP=
#PROTON_WIREGUARD_ENDPOINT_PORT=51820
#PROTON_WIREGUARD_PERSISTENT_KEEPALIVE_INTERVAL=25s

# OIDC + VPN (docker-compose.protonvpn.yml / airvpn): backend talks to IdP from the
# container. If you see "expected 200 OK, got: 403" on login, the IdP may block VPN
# IPs. Route IdP traffic outside the tunnel: resolve OIDC_ISSUER_URL's host, then:
#   getent ahosts auth.example.com
# FIREWALL_OUTBOUND_SUBNETS=203.0.113.10/32,203.0.113.11/32
# Do not overlap your WireGuard tunnel Address range (e.g. 10.2.0.0/…).
#FIREWALL_OUTBOUND_SUBNETS=

# Initial admin account (only used to seed DB on first boot)
ADMIN_NAME=admin
ADMIN_EMAIL=admin@streamhub.local
ADMIN_PASSWORD=change_me

# Required security secrets
JWT_SECRET=replace_with_long_random_hex
SESSION_SECRET=replace_with_long_random_hex
STREAM_PASSWORD=change_me
# Stream token secret — used to generate per-user IPTV playlist tokens
# Generate with: openssl rand -hex 32
STREAM_TOKEN_SECRET=replace_with_long_random_hex

TZ=Europe/Berlin
BACKEND_URL=https://iptv.yourdomain.com

# Optional OIDC / SSO
#OIDC_ISSUER_URL=https://authentik.yourdomain.com/application/o/streamhub/
#OIDC_CLIENT_ID=your-client-id
#OIDC_CLIENT_SECRET=your-client-secret
#OIDC_REDIRECT_URI=https://iptv.yourdomain.com/api/auth/callback
#OIDC_FRONTEND_URL=https://iptv.yourdomain.com
#OIDC_ADMIN_GROUPS=streamhub-admins
